@model IEnumerable<TechMoves_Logistics.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="fa-solid fa-users me-2 text-primary"></i> Client Management</h2>
        <p class="text-muted mb-0">All registered logistics clients</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-2"></i> Register Client
    </a>
</div>

@if (!Model.Any())
{
    <div class="card text-center p-5">
        <i class="fa-solid fa-users-slash fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">No clients registered yet</h5>
        <a asp-action="Create" class="btn btn-primary mt-3">Register First Client</a>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: #1e293b; color: white;">
                        <tr>
                            <th class="py-3 px-4"><i class="fa-solid fa-user me-2"></i> Name</th>
                            <th class="py-3"><i class="fa-solid fa-envelope me-2"></i> Contact Details</th>
                            <th class="py-3"><i class="fa-solid fa-globe me-2"></i> Region</th>
                            <th class="py-3 text-end px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 fw-semibold">@Html.DisplayFor(m => item.Name)</td>
                                <td>@Html.DisplayFor(m => item.ContactDetails)</td>
                                <td>
                                    <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">
                                        <i class="fa-solid fa-location-dot me-1"></i> @Html.DisplayFor(m => item.Region)
                                    </span>
                                </td>
                                <td class="text-end px-4">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1" title="Details">
                                        <i class="fa-solid fa-circle-info"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}