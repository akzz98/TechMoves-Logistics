@model TechMoves_Logistics.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0 text-danger"><i class="fa-solid fa-triangle-exclamation me-2"></i> Delete Client</h2>
                <p class="text-muted mb-0">This action is permanent and cannot be undone</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Back to Clients
            </a>
        </div>

        <!-- Warning Banner -->
        <div class="alert alert-danger border-0 shadow-sm mb-4 d-flex align-items-center gap-3">
            <i class="fa-solid fa-circle-exclamation fa-2x"></i>
            <div>
                <strong>Warning!</strong> You are about to permanently delete this client record.
                All associated contracts and service requests may also be affected.
            </div>
        </div>

        <!-- Record Summary Card -->
        <div class="card shadow-sm border-danger border-2 mb-4">
            <div class="card-header bg-danger text-white py-3">
                <h5 class="mb-0 fw-bold">
                    <i class="fa-solid fa-user me-2"></i> @Model.Name
                </h5>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3 align-items-center">
                    <div class="col-4 text-muted fw-semibold small text-uppercase">
                        <i class="fa-solid fa-building me-2 text-danger"></i> Name
                    </div>
                    <div class="col-8 fw-bold">@Model.Name</div>
                </div>
                <hr class="my-2" />
                <div class="row mb-3 align-items-center">
                    <div class="col-4 text-muted fw-semibold small text-uppercase">
                        <i class="fa-solid fa-envelope me-2 text-danger"></i> Contact
                    </div>
                    <div class="col-8">@Model.ContactDetails</div>
                </div>
                <hr class="my-2" />
                <div class="row mb-3 align-items-center">
                    <div class="col-4 text-muted fw-semibold small text-uppercase">
                        <i class="fa-solid fa-globe me-2 text-danger"></i> Region
                    </div>
                    <div class="col-8">
                        <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2">
                            <i class="fa-solid fa-location-dot me-1"></i> @Model.Region
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="card shadow-sm border-0 p-4">
            <p class="text-muted mb-4 text-center">Are you absolutely sure you want to delete <strong>@Model.Name</strong>?</p>
            <form asp-action="Delete" class="d-flex gap-3 justify-content-center">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2 fw-bold">
                    <i class="fa-solid fa-ban me-2"></i> Cancel
                </a>
                <button type="submit" class="btn btn-danger px-5 py-2 fw-bold shadow">
                    <i class="fa-solid fa-trash me-2"></i> Yes, Delete Client
                </button>
            </form>
        </div>

    </div>
</div>