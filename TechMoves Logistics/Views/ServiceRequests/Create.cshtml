@model TechMoves_Logistics.Models.ServiceRequest

@{
    ViewData["Title"] = "Raise Service Request";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-truck-fast me-2"></i> New Service Payload</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-warning border-0 shadow-sm mb-4">
                            <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.ErrorMessage
                        </div>
                    }

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="ContractId" class="form-label fw-semibold small">Link to Contract</label>
                        <select asp-for="ContractId" class="form-select" asp-items="ViewBag.ContractId">
                            <option value="">-- Select Contract --</option>
                        </select>
                        <span asp-validation-for="ContractId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold small">Task Description</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Describe the cargo or service needed..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Currency Widget -->
                    <div class="card bg-light border-0 mb-4">
                        <div class="card-body">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-3">
                                <i class="fa-solid fa-arrow-right-arrow-left me-1"></i> Currency Calculation
                            </label>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Enter Amount (USD)</label>
                                    <div class="input-group">
                                        <span class="input-group-text">$ USD</span>
                                        <input asp-for="CostUSD" id="usd-input" class="form-control form-control-lg fw-bold" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="CostUSD" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold">Converted Amount (ZAR)</label>
                                    <div class="input-group">
                                        <span class="input-group-text">R ZAR</span>
                                        <input asp-for="CostZAR" id="zar-output" class="form-control form-control-lg fw-bold bg-white" readonly />
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3 d-flex align-items-center justify-content-center gap-2">
                                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">
                                    <i class="fa-solid fa-rotate me-1"></i>
                                    Live Rate: 1 USD = R <span id="rate-display">@ViewBag.ExchangeRate</span>
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label fw-semibold small">Initial Status</label>
                        <select asp-for="Status" class="form-select"
                                asp-items="Html.GetEnumSelectList<TechMoves_Logistics.Models.Enums.ServiceRequestStatus>()">
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary py-3 fw-bold">
                            Submit Logistics Request <i class="fa-solid fa-paper-plane ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Use the rate already fetched by the controller — no extra API call needed
            var rate = parseFloat('@ViewBag.ExchangeRate');

            $("#usd-input").on("input", function () {
                var usd = parseFloat($(this).val());

                if (!isNaN(usd) && usd >= 0) {
                    var zar = usd * rate;
                    $("#zar-output").val(zar.toFixed(2));
                } else {
                    $("#zar-output").val("");
                }
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}