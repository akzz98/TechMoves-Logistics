@model IEnumerable<TechMoves_Logistics.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="fa-solid fa-clipboard-list me-2 text-primary"></i> Service Requests</h2>
        <p class="text-muted mb-0">All logistics service requests across active contracts</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-2"></i> New Request
    </a>
</div>

@if (!Model.Any())
{
    <div class="card text-center p-5">
        <i class="fa-solid fa-clipboard fa-3x text-muted mb-3"></i>
        <h5 class="text-muted">No service requests found</h5>
        <a asp-action="Create" class="btn btn-primary mt-3">Create First Request</a>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background-color: #1e293b; color: white;">
                        <tr>
                            <th class="py-3 px-4"><i class="fa-solid fa-file-contract me-2"></i> Contract</th>
                            <th class="py-3"><i class="fa-solid fa-align-left me-2"></i> Description</th>
                            <th class="py-3"><i class="fa-solid fa-dollar-sign me-2"></i> Cost (USD)</th>
                            <th class="py-3"><i class="fa-solid fa-coins me-2"></i> Cost (ZAR)</th>
                            <th class="py-3"><i class="fa-solid fa-arrow-right-arrow-left me-2"></i> Rate Used</th>
                            <th class="py-3"><i class="fa-solid fa-circle-half-stroke me-2"></i> Status</th>
                            <th class="py-3"><i class="fa-solid fa-clock me-2"></i> Created</th>
                            <th class="py-3 text-end px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 fw-semibold">@Html.DisplayFor(m => item.Contract.ServiceLevel)</td>
                                <td>@Html.DisplayFor(m => item.Description)</td>
                                <td>
                                    <span class="text-muted small">$</span>
                                    <span class="fw-semibold">@item.CostUSD.ToString("N2")</span>
                                </td>
                                <td>
                                    <span class="text-muted small">R</span>
                                    <span class="fw-semibold text-success">@item.CostZAR.ToString("N2")</span>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">@item.ExchangeRateUsed.ToString("N2")</span>
                                </td>
                                <td>
                                    @{
                                        var srBadge = item.Status.ToString() switch
                                        {
                                            "Pending" => "bg-warning text-dark",
                                            "InProgress" => "bg-primary",
                                            "Completed" => "bg-success",
                                            "Cancelled" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @srBadge px-3 py-2">@item.Status</span>
                                </td>
                                <td class="text-muted small">@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="text-end px-4">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1" title="Details">
                                        <i class="fa-solid fa-circle-info"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}