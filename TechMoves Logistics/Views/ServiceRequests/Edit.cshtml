@model TechMoves_Logistics.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <div class="d-flex align-items-center mb-4">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-3">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <div>
                <h2 class="fw-bold mb-0"><i class="fa-solid fa-pen-to-square me-2 text-primary"></i> Edit Service Request</h2>
                <p class="text-muted mb-0 small">Update request details and status</p>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white py-3">
                <h6 class="mb-0 fw-bold"><i class="fa-solid fa-clipboard me-2"></i> Request ID #@Model.Id</h6>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="ContractId" class="form-label fw-semibold small">Linked Contract</label>
                        <select asp-for="ContractId" class="form-select" asp-items="ViewBag.ContractId">
                            <option value="">-- Select Contract --</option>
                        </select>
                        <span asp-validation-for="ContractId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold small">Task Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Describe the cargo or service..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Currency Section -->
                    <div class="card bg-light border-0 mb-3">
                        <div class="card-body">
                            <label class="form-label fw-bold small text-muted text-uppercase mb-3">Cost Details</label>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="CostUSD" class="form-label small fw-semibold">Cost (USD)</label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input asp-for="CostUSD" id="usd-input" class="form-control fw-bold" placeholder="0.00" />
                                    </div>
                                    <span asp-validation-for="CostUSD" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="CostZAR" class="form-label small fw-semibold">Cost (ZAR)</label>
                                    <div class="input-group">
                                        <span class="input-group-text">R</span>
                                        <input asp-for="CostZAR" id="zar-output" class="form-control fw-bold bg-white" readonly />
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 mt-3">
                                <label asp-for="ExchangeRateUsed" class="form-label small fw-semibold">Exchange Rate Used</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fa-solid fa-arrow-right-arrow-left"></i></span>
                                    <input asp-for="ExchangeRateUsed" class="form-control" readonly />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-semibold small">Request Status</label>
                        <select asp-for="Status" class="form-select"
                                asp-items="Html.GetEnumSelectList<TechMoves_Logistics.Models.Enums.ServiceRequestStatus>()">
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="text-decoration-none text-muted small">
                            <i class="fa-solid fa-xmark me-1"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#usd-input").on("input", function () {
                var usd = $(this).val();
                if (usd && !isNaN(usd)) {
                    $.get("/ServiceRequests/GetZarAmount?usd=" + usd, function (data) {
                        $("#zar-output").val(data.toFixed(2));
                    });
                } else {
                    $("#zar-output").val("");
                }
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}