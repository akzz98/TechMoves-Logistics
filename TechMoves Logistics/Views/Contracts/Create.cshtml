@model TechMoves_Logistics.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white py-3">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-file-contract me-2"></i> New Service Level Agreement</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-4">
                        <label asp-for="ClientId" class="form-label fw-semibold small">Assigned Client</label>
                        <select asp-for="ClientId" class="form-select form-select-lg border-2" asp-items="ViewBag.ClientId">
                            <option value="">-- Select Target Client --</option>
                        </select>
                        <span asp-validation-for="ClientId" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-semibold small">Agreement Start</label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-semibold small">Agreement End</label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold small">Initial Status</label>
                            <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<TechMoves_Logistics.Models.Enums.ContractStatus>()"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ServiceLevel" class="form-label fw-semibold small">Service Tier</label>
                            <input asp-for="ServiceLevel" class="form-control" placeholder="e.g. Gold Tier Freight" />
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="form-label fw-semibold text-primary"><i class="fa-solid fa-upload me-1"></i> Signed Agreement (PDF Only)</label>
                        <div class="p-3 border border-2 border-dashed rounded bg-light">
                            <input type="file" name="signedAgreement" class="form-control" accept=".pdf" />
                            <div class="form-text mt-2 small text-muted">Mandatory proof of signature for contract activation.</div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="text-decoration-none text-muted"><i class="fa-solid fa-arrow-left me-1"></i> Back to List</a>
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow">
                            Generate Agreement <i class="fa-solid fa-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}