@model TechMoves_Logistics.Models.Contract

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Contract</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" enctype="multipart/form-data">
            <!-- Support for PDF upload -->
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    
            <div class="form-group mb-3">
                <label asp-for="ClientId" class="control-label">Select Client</label>
                <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId"></select>
            </div>

            <div class="row">
                <div class="form-group col-md-6 mb-3">
                    <label asp-for="StartDate" class="control-label"></label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
                <div class="form-group col-md-6 mb-3">
                    <label asp-for="EndDate" class="control-label"></label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<TechMoves_Logistics.Models.Enums.ContractStatus>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ServiceLevel" class="control-label"></label>
                <input asp-for="ServiceLevel" class="form-control" />
                <span asp-validation-for="ServiceLevel" class="text-danger"></span>
            </div>

            <!-- REPLACED: Path string with File Input -->
            <div class="form-group mb-4">
                <label class="control-label font-weight-bold">Signed Agreement (PDF Only)</label>
                <input type="file" name="signedAgreement" class="form-control" accept=".pdf" />
                <small class="text-muted">Max file size: 5MB</small>
            </div>

            <div class="form-group">
                <input type="submit" value="Save Contract" class="btn btn-success w-100" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
