@model dynamic
@{
    ViewData["Title"] = "Operations Dashboard";
}

<div class="row mb-4">
    <div class="col">
        <h2 class="fw-bold text-dark">Welcome back, Logistics Admin</h2>
        <p class="text-muted">Global Operations Overview for Tech Moves</p>
    </div>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 p-3 border-start border-primary border-4">
            <div class="d-flex align-items-center">
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                    <i class="fa-solid fa-user-tie fa-2x text-primary"></i>
                </div>
                <div>
                    <h6 class="text-uppercase text-muted fw-bold small mb-0">Total Clients</h6>
                    <h3 class="fw-bold mb-0">Active Portfolios</h3>
                </div>
            </div>
            <a asp-controller="Clients" asp-action="Index" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3 border-start border-success border-4">
            <div class="d-flex align-items-center">
                <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                    <i class="fa-solid fa-file-signature fa-2x text-success"></i>
                </div>
                <div>
                    <h6 class="text-uppercase text-muted fw-bold small mb-0">Active Contracts</h6>
                    <h3 class="fw-bold mb-0">Compliance Ready</h3>
                </div>
            </div>
            <a asp-controller="Contracts" asp-action="Index" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-3 border-start border-warning border-4">
            <div class="d-flex align-items-center">
                <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
                    <i class="fa-solid fa-truck-ramp-box fa-2x text-warning"></i>
                </div>
                <div>
                    <h6 class="text-uppercase text-muted fw-bold small mb-0">Service Requests</h6>
                    <h3 class="fw-bold mb-0">In Progress</h3>
                </div>
            </div>
            <a asp-controller="ServiceRequests" asp-action="Index" class="stretched-link"></a>
        </div>
    </div>
</div>

<!-- Quick Actions Section -->
<div class="row">
    <div class="col-md-8">
        <div class="card p-4 h-100">
            <h5 class="fw-bold mb-4"><i class="fa-solid fa-bolt me-2 text-primary"></i> Quick Actions</h5>
            <div class="row g-3">
                <div class="col-sm-6">
                    <a asp-controller="Clients" asp-action="Create" class="btn btn-outline-primary w-100 py-3 fw-bold">
                        <i class="fa-solid fa-plus me-2"></i> Register New Client
                    </a>
                </div>
                <div class="col-sm-6">
                    <a asp-controller="Contracts" asp-action="Create" class="btn btn-outline-primary w-100 py-3 fw-bold">
                        <i class="fa-solid fa-file-circle-plus me-2"></i> Create Contract
                    </a>
                </div>
                <div class="col-sm-6">
                    <a asp-controller="ServiceRequests" asp-action="Create" class="btn btn-outline-primary w-100 py-3 fw-bold">
                        <i class="fa-solid fa-cart-plus me-2"></i> New Service Request
                    </a>
                </div>
                <div class="col-sm-6">
                    <a asp-controller="Contracts" asp-action="Index" class="btn btn-outline-secondary w-100 py-3 fw-bold">
                        <i class="fa-solid fa-magnifying-glass me-2"></i> Search Agreements
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-4 bg-dark text-white h-100">
            <h5 class="fw-bold mb-3">System Health</h5>
            <hr class="bg-secondary" />
            <div class="mb-3">
                <small class="text-secondary">Currency API Status</small>
                <p class="mb-0 text-success fw-bold"><i class="fa-solid fa-circle-check me-2"></i> Connected</p>
            </div>
            <div class="mb-3">
                <small class="text-secondary">Signed Agreement Server</small>
                <p class="mb-0 text-success fw-bold"><i class="fa-solid fa-circle-check me-2"></i> Operational</p>
            </div>
        </div>
    </div>
</div>